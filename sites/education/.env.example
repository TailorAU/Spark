# Education API URL (defaults to localhost:5300 for local dev)
# In production, set to the deployed Education API URL
NEXT_PUBLIC_API_URL=http://localhost:5300/api

# Authentication is handled by Azure Static Web Apps built-in auth
# Configure in Azure Portal > Static Web App > Settings > Authentication
# Entra ID (Azure AD) is the pre-configured provider at /.auth/login/aad
# No additional env vars needed — SWA manages auth at the infrastructure level
